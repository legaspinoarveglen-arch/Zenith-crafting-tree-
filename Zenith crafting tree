<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Interactive Zenith Crafting Tree | Terraria 1.4.5+</title>
    <style>
        :root {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --text-color: #e0e0e0;
            --accent-color: #00cf7f;
            --secondary-accent: #008f58;
            --border-color: #333;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 0;
            line-height: 1.6;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Hero Section */
        header {
            text-align: center;
            padding: 60px 20px;
            background: linear-gradient(180deg, #1a1a1a 0%, #121212 100%);
            border-bottom: 2px solid var(--accent-color);
            margin-bottom: 30px;
        }

        h1 {
            font-size: 3rem;
            margin: 0;
            color: var(--accent-color);
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .stats-bar {
            display: inline-block;
            background: var(--card-bg);
            padding: 10px 20px;
            border-radius: 50px;
            margin-top: 15px;
            font-weight: bold;
            border: 1px solid var(--border-color);
        }

        .stats-bar span { color: var(--accent-color); margin: 0 10px; }

        /* AD SPACE TOP */
        /* */

        h2 {
            text-align: center;
            color: var(--accent-color);
            margin-top: 40px;
            font-size: 1.8rem;
        }

        /* The Grid */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            display: flex;
            align-items: center;
            transition: transform 0.2s, border-color 0.2s;
            position: relative;
        }

        .card:hover {
            border-color: var(--accent-color);
            transform: translateY(-5px);
        }

        .checkbox-container {
            margin-right: 20px;
        }

        input[type="checkbox"] {
            width: 25px;
            height: 25px;
            cursor: pointer;
            accent-color: var(--accent-color);
        }

        .info h3 {
            margin: 0;
            font-size: 1.2rem;
        }

        .badge {
            display: inline-block;
            background: #333;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            margin-top: 5px;
            color: var(--accent-color);
            border: 1px solid var(--secondary-accent);
        }

        /* Sub-Tree Section */
        .sub-tree {
            background: #1a1a1a;
            border: 1px dashed var(--border-color);
            border-radius: 15px;
            padding: 30px;
            margin: 40px 0;
        }

        .recipe-box {
            background: var(--bg-color);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .recipe-box strong { color: var(--accent-color); }

        footer {
            text-align: center;
            padding: 40px;
            color: #666;
            font-size: 0.9rem;
        }

        /* Mobile Adjustments */
        @media (max-width: 600px) {
            h1 { font-size: 2rem; }
            .grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

